#  .env.example — SCN-051/052 Secrets Management
#  این فایل را کپی کنید به .env و مقادیر واقعی را جایگزین کنید
#  هرگز فایل .env واقعی را commit نکنید
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── JWT ─────────────────────────────────────────────────────
# حداقل ۳۲ کاراکتر random — دستور تولید: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_RANDOM_64_BYTE_HEX
JWT_REFRESH_EXPIRES_IN=30d

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/yourdb

# ── AWS S3 ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_WITH_REAL_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_REAL_SECRET
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_API_KEY=REPLACE_WITH_REAL_KEY
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_MEASUREMENT_ID=G-XXXXXXXX

# ── Firebase Admin SDK (سرور) ────────────────────────────────
# مسیر فایل service account — این فایل باید در .gitignore باشد
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# یا به صورت JSON string (برای محیط<200c>های cloud):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=REPLACE_WITH_REAL_PASS

# ── OTP / SMS ────────────────────────────────────────────────
SMS_API_KEY=REPLACE_WITH_REAL_KEY
SMS_API_URL=https://api.sms-provider.com

# ── Encryption ───────────────────────────────────────────────
# برای رمزنگاری داده<200c>های حساس در DB
ENCRYPTION_KEY=REPLACE_WITH_RANDOM_32_BYTE_HEX